<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="String Encrypt / Decrypt"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="?attr/colorPrimary"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_encrypt_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Input text"
                    android:singleLine="true"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <Button
                        android:id="@+id/btn_encrypt"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Encrypt"
                        android:layout_marginEnd="4dp" />

                    <Button
                        android:id="@+id/btn_decrypt"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Decrypt"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_encrypt_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Result: "
                    android:fontFamily="monospace"
                    android:textIsSelectable="true"
                    android:background="@drawable/bg_log_container"
                    android:padding="8dp"
                    android:textSize="12sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Signature Verification"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="?attr/colorPrimary"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_sign_data"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Data to verify"
                    android:singleLine="true"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_sign_signature"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Signature (leave empty for auto-generate)"
                    android:singleLine="true"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btn_verify"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Verify Signature"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_verify_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Result: "
                    android:fontFamily="monospace"
                    android:textIsSelectable="true"
                    android:background="@drawable/bg_log_container"
                    android:padding="8dp"
                    android:textSize="12sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Log"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_native_logs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="150dp"
            android:background="@drawable/bg_log_container" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
